# OpsCat configuration — copy to .env and fill in. Never commit .env.
# --- required ---
OPSCAT_DOMAIN=localhost                  # your domain; Caddy auto-provisions TLS
OPSCAT_BASE_URL=http://localhost         # public base URL (https://<domain> in prod)
OPSCAT_SECRET=                           # long random string (cookies/crypto); generate once
OPSCAT_ADMIN_EMAIL=                      # first admin user, seeded on first boot

# --- optional: e-mail via Resend (alerts + magic-link login) ---
RESEND_API_KEY=
OPSCAT_ALERT_FROM=
OPSCAT_AUTH_FROM=

# --- optional: label for the built-in probe location ---
OPSCAT_PROBE_CITY=Local
OPSCAT_PROBE_CC=XX
